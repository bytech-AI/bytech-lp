	animation: button-anime 2s linear infinite;
}

@keyframes button-anime {
  0% {
    transform: scale(1);
  }
  10% {
    transform: scale(1.05);
  }
  20% {
    transform: scale(1);
  }
  100% {
    transform: scale(1);
  }
}

/* 学べる内容SPカルーセル */
.slider-group {
    position: relative;
    width: 100%;
    min-height: 200px;
    height: auto;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: scroll;
		column-gap: 15px;
}

.carousel-col {
		padding: 10px 0px 0px 5px;
    flex: 0 0 auto;
    max-width: 100%;
    height: 100%;
}
.card-sp {
    width: 260px;
    height: auto;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 1px 5px rgba(0,0,0,.2);
}

.card__textbox {
    width: 100%;
    height: 200px;
    padding: 25px 15px 15px 15px;
    background: #fff;
    box-sizing: border-box;
}

.card__titletext {
    font-size: 16px;
    font-weight: 700;
    line-height: 125%;
    letter-spacing: 0.05em;
    color: #333;
}

.card__subtext {
		margin-top: 5px;
		font-size: 12px;
    font-weight: 700;
    line-height: 125%;
    letter-spacing: 0.05em;
    color: #333;
}
	
.card__overviewtext {
    font-size: 12px;
    margin-top: 15px;
    line-height: 150%;
    letter-spacing: 0.01em;
    color: #333;
}
/* 固定CTA表示アクション */
.fixed-footer-cta{
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all .3s ease;
  z-index: 9999;
}

/* 表示状態 */
.fixed-footer-cta.is-visible{
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

:root {
    --cs-navy: #0B1D3A;
    --cs-blue: #533AFC;
    --cs-blue-dark: #3D28D4;
    --cs-blue-light: #EEEAFF;
    --cs-accent: #00B4D8;
    --cs-green: #10B981;
    --cs-green-light: #ECFDF5;
    --cs-red: #EF4444;
    --cs-card: #FFFFFF;
    --cs-text: #1A2638;
    --cs-text-sub: #5E7082;
    --cs-border: #E2E8F0;
    --cs-gray: #F4F6F9;
    --radius: 12px;
    --shadow: 0 4px 20px rgba(0,30,80,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Noto Sans JP', sans-serif; color: var(--cs-text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .cs-wrapper { max-width: 440px; margin: 0 auto; padding: 0 14px; }
  .cs-header { text-align: center; padding: 20px 0 14px; }
  .cs-progress { display: flex; align-items: center; justify-content: center; margin: 0 0 16px; }
  .cs-step { display: flex; flex-direction: column; align-items: center; flex: 1; z-index: 2; }
  .cs-dot { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; background: var(--cs-gray); color: var(--cs-text-sub); border: 2px solid var(--cs-border); transition: all 0.4s; }
  .cs-step.active .cs-dot { background: var(--cs-blue); color: #fff; border-color: var(--cs-blue); box-shadow: 0 0 0 4px rgba(83,58,252,0.15); animation: csDotPulse 2s ease-in-out infinite; }
  .cs-step.done .cs-dot { background: var(--cs-green); color: #fff; border-color: var(--cs-green); animation: none; }
  .cs-step.done .cs-dot-num { display: none; }
  .cs-step.done .cs-dot::after { content: '✓'; font-size: 13px; }
  @keyframes csDotPulse { 0%, 100% { box-shadow: 0 0 0 4px rgba(83,58,252,0.15); } 50% { box-shadow: 0 0 0 7px rgba(83,58,252,0.07); } }
  .cs-dot-label { font-size: 10px; font-weight: 600; color: var(--cs-text-sub); margin-top: 4px; white-space: nowrap; }
  .cs-step.active .cs-dot-label, .cs-step.done .cs-dot-label { color: var(--cs-blue); }
  .cs-conn { flex: 0.4; height: 2px; background: var(--cs-border); margin-bottom: 18px; border-radius: 1px; overflow: hidden; }
  .cs-conn-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--cs-green), var(--cs-blue)); transition: width 0.5s; }
  .cs-conn.filled .cs-conn-fill { width: 100%; }
  .cs-conn.half .cs-conn-fill { width: 50%; }
  .cs-card { background: var(--cs-card); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .cs-card-accent { height: 3px; background: linear-gradient(90deg, var(--cs-navy), var(--cs-blue)); }
  .cs-card-body { padding: 24px 20px; }
  .cs-panel { display: none; animation: csFade 0.3s ease-out; }
  .cs-panel.active { display: block; }
  @keyframes csFade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .cs-day-toggle { display: flex; background: var(--cs-gray); border-radius: 10px; padding: 4px; margin-bottom: 20px; }
  .cs-day-btn { flex: 1; padding: 12px 8px; text-align: center; border: none; border-radius: 8px; background: transparent; font-family: inherit; font-size: 14px; font-weight: 600; color: var(--cs-text-sub); cursor: pointer; transition: all 0.25s; }
  .cs-day-btn.active { background: var(--cs-blue); color: #fff; box-shadow: 0 2px 8px rgba(83,58,252,0.3); }
  .cs-day-btn:not(.active):hover { background: rgba(83,58,252,0.08); color: var(--cs-blue); }
  .cs-day-btn .cs-day-label { display: block; font-size: 11px; font-weight: 500; opacity: 0.8; margin-top: 2px; }
  .cs-day-btn.active .cs-day-label { opacity: 1; }
  .cs-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .cs-skeleton { background: linear-gradient(90deg, #eee 25%, #f8f8f8 50%, #eee 75%); background-size: 200% 100%; animation: csShimmer 1.5s infinite; border-radius: 8px; height: 56px; }
  @keyframes csShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .cs-slot { border: 2px solid var(--cs-border); border-radius: 10px; padding: 14px 6px; text-align: center; cursor: pointer; transition: all 0.2s; background: var(--cs-card); }
  .cs-slot:hover { border-color: #C4B9FD; transform: translateY(-1px); }
  .cs-slot.selected { border-color: var(--cs-blue); background: var(--cs-blue-light); box-shadow: 0 0 0 3px rgba(83,58,252,0.12); }
  .cs-slot-time { font-size: 20px; font-weight: 800; color: var(--cs-text); letter-spacing: -0.5px; }
  .cs-slot.selected .cs-slot-time { color: var(--cs-blue); }
  .cs-cap { font-size: 10px; font-weight: 700; margin-top: 4px; padding: 1px 6px; border-radius: 4px; display: inline-block; }
  .cs-cap-ok { background: #E6F9EE; color: #059669; }
  .cs-cap-few { background: #FFF7E6; color: #D97706; }
  .cs-cap-last { background: #FEE2E2; color: #DC2626; }
  .cs-no-slots { text-align: center; padding: 28px 16px; color: var(--cs-text-sub); grid-column: span 3; }
  .cs-no-slots p { font-size: 14px; margin-bottom: 4px; }
  .cs-no-slots small { font-size: 12px; }
  .cs-time-bar { display: flex; align-items: center; gap: 8px; background: var(--cs-blue-light); color: var(--cs-blue); font-size: 13px; font-weight: 600; padding: 10px 14px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid var(--cs-blue); }
  .cs-time-bar svg { width: 16px; height: 16px; flex-shrink: 0; }
  .cs-field { margin-bottom: 16px; }
  .cs-label { display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--cs-text); margin-bottom: 5px; }
  .cs-req { font-size: 9px; font-weight: 700; color: #fff; background: var(--cs-red); padding: 1px 5px; border-radius: 3px; }
  .cs-input { width: 100%; padding: 12px 14px; font-size: 15px; font-family: inherit; color: var(--cs-text); background: var(--cs-gray); border: 2px solid transparent; border-radius: 8px; outline: none; transition: all 0.2s; -webkit-appearance: none; }
  .cs-input:focus { background: #fff; border-color: var(--cs-blue); box-shadow: 0 0 0 3px rgba(83,58,252,0.1); }
  .cs-input.error { border-color: var(--cs-red); background: #FEF2F2; }
  .cs-input::placeholder { color: #A0AEC0; }
  .cs-err { font-size: 11px; color: var(--cs-red); margin-top: 3px; display: none; }
  .cs-err.show { display: block; }
  .cs-btn-row { display: flex; gap: 8px; margin-top: 24px; }
  .cs-btn { flex: 1; padding: 14px 16px; font-size: 15px; font-family: inherit; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; transition: all 0.2s; -webkit-appearance: none; }
  .cs-btn:active { transform: scale(0.98); }
  .cs-btn-next { background: var(--cs-blue); color: #fff; box-shadow: 0 2px 8px rgba(83,58,252,0.25); }
  .cs-btn-next:hover { background: var(--cs-blue-dark); }
  .cs-btn-next:disabled { background: #B0C4DE; box-shadow: none; cursor: not-allowed; }
  .cs-btn-back { background: var(--cs-gray); color: var(--cs-text-sub); flex: 0.4; }
  .cs-btn-back:hover { background: var(--cs-border); }
  .cs-btn-submit { background: linear-gradient(135deg, var(--cs-navy), var(--cs-blue)); color: #fff; box-shadow: 0 4px 16px rgba(83,58,252,0.25); position: relative; overflow: hidden; }
  .cs-btn-submit:hover { box-shadow: 0 6px 20px rgba(83,58,252,0.35); transform: translateY(-1px); }
  .cs-btn-submit:active { transform: translateY(0) scale(0.98); }
  .cs-btn-submit::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent); transform: translateX(-100%); animation: csShine 3s infinite; }
  @keyframes csShine { 0% { transform: translateX(-100%); } 30%, 100% { transform: translateX(100%); } }
  .cs-btn .cs-spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: csSpin 0.6s linear infinite; margin: 0 auto; }
  .cs-btn.loading .cs-btn-text { display: none; }
  .cs-btn.loading .cs-spinner { display: inline-block; }
  @keyframes csSpin { to { transform: rotate(360deg); } }
  .cs-counter { text-align: center; font-size: 11px; color: var(--cs-text-sub); margin-top: 12px; }
  .cs-view-all { text-align: center; margin-top: 14px; }
  .cs-view-all a { display: inline-flex; align-items: center; gap: 5px; color: var(--cs-blue); font-size: 13px; font-weight: 600; text-decoration: none; padding: 8px 18px; border: 1.5px solid var(--cs-blue); border-radius: 24px; transition: all 0.2s; }
  .cs-view-all a:hover { background: var(--cs-blue-light); }
  .cs-view-all a svg { width: 14px; height: 14px; }
  @media (max-width: 380px) { .cs-wrapper { padding: 0 10px; } .cs-card-body { padding: 20px 16px; } .cs-slots { grid-template-columns: repeat(2, 1fr); } .cs-no-slots { grid-column: span 2; } .cs-slot-time { font-size: 18px; } }

/* フルカレンダー */
  :root {
    --fc-primary: #4F46E5;
    --fc-primary-light: #6C5CE7;
    --fc-primary-bg: #F5F3FF;
    --fc-bg: #ffffff;
    --fc-card-bg: #ffffff;
    --fc-text: #1a1a2e;
    --fc-text-sub: #888;
    --fc-border: #eee;
    --fc-radius: 14px;
    --fc-err: #e74c3c;
    --fc-row-h: 72px;
  }
  .fc-wrapper{max-width:720px;margin:0 auto;padding:20px 16px 32px;font-family:'Helvetica Neue',Arial,'Hiragino Kaku Gothic ProN',Meiryo,sans-serif;color:var(--fc-text);-webkit-font-smoothing:antialiased}
  .fc-progress{display:flex;align-items:center;justify-content:center;gap:0;margin:0 0 20px;padding:0 10px}
  .fc-step{display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0}
  .fc-dot{width:30px;height:30px;border-radius:50%;background:#e0e0e0;display:flex;align-items:center;justify-content:center;transition:all .3s}
  .fc-dot-num{font-size:13px;font-weight:700;color:#999;transition:all .3s}
  .fc-dot-label{font-size:11px;color:#999;font-weight:600;white-space:nowrap;transition:all .3s}
  .fc-step.active .fc-dot{background:var(--fc-primary);box-shadow:0 2px 8px rgba(79,70,229,.3)}
  .fc-step.active .fc-dot-num{color:#fff}
  .fc-step.active .fc-dot-label{color:var(--fc-primary)}
  .fc-step.done .fc-dot{background:var(--fc-primary)}
  .fc-step.done .fc-dot-num{color:#fff}
  .fc-step.done .fc-dot-label{color:var(--fc-primary)}
  .fc-conn{flex:1;height:3px;background:#e0e0e0;border-radius:2px;margin:0 6px;position:relative;margin-bottom:18px;overflow:hidden}
  .fc-conn-fill{position:absolute;top:0;left:0;height:100%;width:0;background:var(--fc-primary);border-radius:2px;transition:width .4s}
  .fc-conn.half .fc-conn-fill{width:50%}
  .fc-conn.filled .fc-conn-fill{width:100%}
  .fc-card{background:var(--fc-card-bg);border-radius:var(--fc-radius);box-shadow:0 2px 16px rgba(0,0,0,.06);overflow:hidden;position:relative}
  .fc-card-accent{height:4px;background:linear-gradient(90deg,var(--fc-primary),var(--fc-primary-light))}
  .fc-card-body{padding:20px}
  .fc-panel{display:none}
  .fc-panel.active{display:block;animation:fcFadeIn .3s ease}
  @keyframes fcFadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  .fc-cal-title-bar{text-align:center;font-size:15px;font-weight:700;color:var(--fc-text);margin-bottom:14px}
  .fc-grid-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
  .fc-grid{display:grid;grid-template-columns:50px repeat(5,1fr);min-width:480px}
  .fc-grid-corner{border-bottom:2px solid var(--fc-border)}
  .fc-dh{text-align:center;padding:8px 0 10px;border-bottom:2px solid var(--fc-border)}
  .fc-dh-dow{font-size:12px;font-weight:700;color:var(--fc-text-sub)}
  .fc-dh-date{font-size:17px;font-weight:800;color:var(--fc-text);margin-top:1px}
  .fc-dh.today .fc-dh-dow,.fc-dh.today .fc-dh-date{color:var(--fc-primary)}
  .fc-tl{display:flex;align-items:center;justify-content:flex-end;font-size:11px;font-weight:700;color:var(--fc-text-sub);height:var(--fc-row-h);border-right:1px solid var(--fc-border);border-bottom:1px solid #f5f5f5;padding-right:8px;box-sizing:border-box}
  .fc-cell{height:var(--fc-row-h);border-bottom:1px solid #f5f5f5;padding:3px;display:flex;align-items:center;justify-content:center;box-sizing:border-box}
  .fc-slot{width:100%;height:100%;border-radius:10px;border:1.5px solid var(--fc-border);background:var(--fc-bg);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;transition:all .15s;padding:2px}
  .fc-slot:hover{border-color:var(--fc-primary);background:var(--fc-primary-bg)}
  .fc-slot.selected{border-color:var(--fc-primary);background:var(--fc-primary);transform:scale(1.03)}
  .fc-slot.selected .fc-slot-range{color:rgba(255,255,255,.7)}
  .fc-slot.selected .fc-badge-icon,.fc-slot.selected .fc-badge-text{color:#fff!important}
  .fc-slot-range{font-size:9px;font-weight:600;color:var(--fc-text-sub);line-height:1;margin-bottom:1px}
  .fc-badge{display:flex;flex-direction:column;align-items:center;gap:1px;line-height:1}
  .fc-badge-icon{font-size:18px;font-weight:900;line-height:1}
  .fc-badge-text{font-size:10px;font-weight:800;letter-spacing:.3px}
  .fc-badge-ok .fc-badge-icon,.fc-badge-ok .fc-badge-text{color:#27ae60}
  .fc-badge-few .fc-badge-icon,.fc-badge-few .fc-badge-text{color:#e67e22}
  .fc-badge-last .fc-badge-icon,.fc-badge-last .fc-badge-text{color:#e74c3c}
  .fc-skeleton{height:var(--fc-row-h);margin:3px;border-radius:10px;background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%);background-size:200% 100%;animation:fcShimmer 1.5s infinite}
  @keyframes fcShimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
  .fc-time-bar-d{display:flex;align-items:center;gap:8px;background:var(--fc-primary-bg);padding:10px 14px;border-radius:10px;margin-bottom:16px;font-size:14px;font-weight:600;color:var(--fc-primary)}
  .fc-time-bar-d svg{width:18px;height:18px;flex-shrink:0}
  .fc-field{margin-bottom:14px}
  .fc-label{display:block;font-size:13px;font-weight:700;color:var(--fc-text);margin-bottom:5px}
  .fc-req{color:var(--fc-err);font-size:11px;font-weight:700}
  .fc-opt{color:var(--fc-text-sub);font-size:11px;font-weight:600}
  .fc-input{width:100%;padding:11px 14px;border:1.5px solid var(--fc-border);border-radius:10px;font-size:15px;color:var(--fc-text);outline:none;transition:border .2s;box-sizing:border-box;font-family:inherit}
  .fc-input:focus{border-color:var(--fc-primary)}
  .fc-input.error{border-color:var(--fc-err);background:#fef2f2}
  .fc-textarea{resize:vertical;min-height:80px}
  .fc-err-msg{display:none;font-size:12px;color:var(--fc-err);margin-top:4px;font-weight:600}
  .fc-err-msg.show{display:block}
  .fc-radio-group{display:flex;flex-direction:column;gap:8px}
  .fc-radio-item{display:flex;align-items:center;gap:10px;padding:10px 14px;border:1.5px solid var(--fc-border);border-radius:10px;cursor:pointer;transition:all .2s}
  .fc-radio-item:hover{border-color:var(--fc-primary);background:var(--fc-primary-bg)}
  .fc-radio-item.selected{border-color:var(--fc-primary);background:var(--fc-primary-bg)}
  .fc-radio-dot{width:18px;height:18px;border-radius:50%;border:2px solid #ccc;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s}
  .fc-radio-item.selected .fc-radio-dot{border-color:var(--fc-primary)}
  .fc-radio-dot-inner{width:10px;height:10px;border-radius:50%;background:var(--fc-primary);transform:scale(0);transition:transform .2s}
  .fc-radio-item.selected .fc-radio-dot-inner{transform:scale(1)}
  .fc-radio-text{font-size:14px;font-weight:600;color:var(--fc-text)}
  .fc-btn-row{display:flex;gap:10px;margin-top:18px}
  .fc-btn{flex:1;padding:14px 16px;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;font-family:inherit;position:relative}
  .fc-btn-next{background:var(--fc-primary);color:#fff}
  .fc-btn-next:hover{background:#4338CA}
  .fc-btn-next:disabled{opacity:.4;cursor:not-allowed}
  .fc-btn-back{background:#f0f0f0;color:var(--fc-text-sub)}
  .fc-btn-back:hover{background:#e5e5e5}
  .fc-btn-submit{background:var(--fc-primary);color:#fff}
  .fc-btn-submit:hover{background:#4338CA}
  .fc-btn-submit.loading .fc-btn-text{visibility:hidden}
  .fc-btn-submit.loading .fc-spinner{display:block}
  .fc-spinner{display:none;width:22px;height:22px;border:3px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:fcSpin .6s linear infinite;position:absolute;top:50%;left:50%;margin:-11px 0 0 -11px}
  @keyframes fcSpin{to{transform:rotate(360deg)}}
  .fc-counter{text-align:center;font-size:12px;color:var(--fc-text-sub);margin-top:12px;font-weight:600}
  .fc-conf-header{font-size:11px;font-weight:700;color:var(--fc-text-sub);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;padding-bottom:5px;border-bottom:1px solid var(--fc-border)}
  .fc-conf-row{display:flex;justify-content:space-between;padding:6px 0;font-size:14px}
  .fc-conf-label{color:var(--fc-text-sub)}
  .fc-conf-value{font-weight:600;text-align:right;max-width:60%;word-break:break-all}
  @media(max-width:560px){
    .fc-wrapper{padding:12px 8px 24px}
    .fc-card-body{padding:14px 10px}
    .fc-slot-range{font-size:8px}
    .fc-badge-icon{font-size:14px}
    .fc-badge-text{font-size:8px}
    .fc-tl{font-size:10px;padding-right:5px}
    .fc-dh-date{font-size:14px}
    .fc-dh-dow{font-size:10px}
    :root{--fc-row-h:64px}
    .fc-grid{grid-template-columns:38px repeat(5,1fr);min-width:360px}
  }
		</style>
